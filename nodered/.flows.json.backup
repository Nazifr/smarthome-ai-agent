    {
        "id": "mqtt-sensor-in",
        "type": "mqtt in",
        "z": "44162578c2bd78b4",
        "name": "Sensör Verisi",
        "topic": "home/+/sensor/all",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt-broker-1",
        "inputs": 0,
        "x": 110,
        "y": 120,
        "wires": [
            [
                "parse-sensor"
            ]
        ]
    },
    {
        "id": "parse-sensor",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Veriyi Ayrıştır",
        "func": "var data = msg.payload;\nvar room = msg.topic.split('/')[1];\nmsg.temperature = data.temperature;\nmsg.humidity = data.humidity;\nmsg.motion = data.motion;\nmsg.light = data.light;\nmsg.room = room;\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 120,
        "wires": [
            [
                "set-temp",
                "set-humidity",
                "set-motion",
                "set-light"
            ]
        ]
    },
    {
        "id": "set-temp",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Sıcaklık",
        "func": "msg.payload = msg.temperature;\nreturn msg;",
        "outputs": 1,
        "x": 530,
        "y": 80,
        "wires": [
            [
                "ui-temp-gauge"
            ]
        ]
    },
    {
        "id": "set-humidity",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Nem",
        "func": "msg.payload = msg.humidity;\nreturn msg;",
        "outputs": 1,
        "x": 530,
        "y": 140,
        "wires": [
            [
                "ui-humidity-gauge"
            ]
        ]
    },
    {
        "id": "set-motion",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Hareket",
        "func": "msg.payload = msg.motion === 1 ? 'VAR ✓' : 'YOK';\nreturn msg;",
        "outputs": 1,
        "x": 530,
        "y": 200,
        "wires": [
            [
                "ui-motion-text"
            ]
        ]
    },
    {
        "id": "set-light",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Işık",
        "func": "msg.payload = msg.light;\nreturn msg;",
        "outputs": 1,
        "x": 530,
        "y": 260,
        "wires": [
            [
                "ui-light-gauge"
            ]
        ]
    },
    {
        "id": "ui-temp-gauge",
        "type": "ui_gauge",
        "z": "44162578c2bd78b4",
        "name": "Sıcaklık",
        "group": "ui_group_temp",
        "order": 1,
        "width": 3,
        "height": 3,
        "gtype": "gage",
        "title": "Sıcaklık",
        "label": "°C",
        "format": "{{value}}",
        "min": 0,
        "max": 50,
        "colors": [
            "#0000ff",
            "#00ff00",
            "#ff0000"
        ],
        "seg1": 18,
        "seg2": 28,
        "x": 730,
        "y": 80,
        "wires": []
    },
    {
        "id": "ui-humidity-gauge",
        "type": "ui_gauge",
        "z": "44162578c2bd78b4",
        "name": "Nem",
        "group": "ui_group_temp",
        "order": 2,
        "width": 3,
        "height": 3,
