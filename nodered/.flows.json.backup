        "x": 730,
        "y": 140,
        "wires": []
    },
    {
        "id": "ui-motion-text",
        "type": "ui_text",
        "z": "44162578c2bd78b4",
        "group": "ui_group_motion",
        "order": 1,
        "width": 3,
        "height": 2,
        "name": "Hareket",
        "format": "{{msg.payload}}",
        "x": 730,
