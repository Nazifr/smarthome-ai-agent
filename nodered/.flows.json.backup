    {
        "id": "format-alert",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Uyarıyı Formatla",
        "func": "var data = msg.payload;\nvar time = new Date().toLocaleTimeString('tr-TR');\nmsg.payload = time + ' | ' + data.message;\nreturn msg;",
        "outputs": 1,
        "x": 330,
        "y": 640,
        "wires": [
            [
                "ui-alert-text"
            ]
        ]
    },
    {
