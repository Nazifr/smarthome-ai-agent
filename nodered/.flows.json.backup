            "#ffcc00",
            "#ffffff"
        ],
        "seg1": 50,
        "seg2": 300,
        "x": 730,
        "y": 260,
        "wires": []
    },
    {
        "id": "mqtt-agent-in",
        "type": "mqtt in",
        "z": "44162578c2bd78b4",
        "name": "Agent Komutları",
        "topic": "home/+/+/command",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt-broker-1",
        "inputs": 0,
        "x": 110,
        "y": 440,
        "wires": [
            [
                "parse-agent-decision"
            ]
        ]
    },
    {
        "id": "parse-agent-decision",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Kararı Ayrıştır",
        "func": "var parts = msg.topic.split('/');\nvar room = parts[1];\nvar device = parts[2];\nvar data = msg.payload;\nvar time = new Date().toLocaleTimeString('tr-TR');\n\nmsg.room = room;\nmsg.device = device;\nmsg.command = data.command;\nmsg.reason = data.reason;\nmsg.method = data.method || 'heuristic';\nmsg.confidence = data.confidence || '—';\nmsg.context_label = data.context_label || '—';\nmsg.time = time;\n\nreturn [msg, msg, msg, msg];",
        "outputs": 4,
        "x": 350,
        "y": 440,
        "wires": [
            [
                "set-decision-text"
            ],
            [
                "set-context-text"
            ],
            [
                "set-confidence-text"
            ],
            [
                "set-reason-text"
            ]
        ]
    },
    {
        "id": "set-decision-text",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Karar",
        "func": "msg.payload = msg.time + '\\n' + msg.room + ' → ' + msg.device + ': ' + msg.command;\nreturn msg;",
        "outputs": 1,
        "x": 570,
        "y": 400,
        "wires": [
            [
                "ui-decision-text"
            ]
        ]
    },
    {
        "id": "set-context-text",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Bağlam",
        "func": "msg.payload = msg.context_label + '\\nYöntem: ' + msg.method;\nreturn msg;",
        "outputs": 1,
        "x": 570,
        "y": 450,
        "wires": [
            [
                "ui-context-text"
            ]
        ]
    },
    {
        "id": "set-confidence-text",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Güven",
        "func": "msg.payload = msg.confidence;\nreturn msg;",
        "outputs": 1,
        "x": 570,
        "y": 500,
        "wires": [
            [
                "ui-confidence-text"
            ]
        ]
    },
    {
        "id": "set-reason-text",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Gerekçe",
        "func": "msg.payload = msg.time + ' | ' + msg.reason;\nreturn msg;",
        "outputs": 1,
        "x": 570,
        "y": 550,
        "wires": [
            [
                "ui-reason-text"
            ]
        ]
    },
    {
        "id": "ui-decision-text",
        "type": "ui_text",
        "z": "44162578c2bd78b4",
        "group": "ui_group_agent_decision",
        "order": 1,
