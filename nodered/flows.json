    {
        "id": "cf32e3ac061e8823",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Kararı Ayrıştır",
        "func": "var parts = msg.topic.split('/');\nvar room = parts[1];\nvar device = parts[2];\nvar data = msg.payload;\nvar time = new Date().toLocaleTimeString('tr-TR');\n\nmsg.room = room;\nmsg.device = device;\nmsg.command = data.command;\nmsg.reason = data.reason;\nmsg.method = data.method || 'heuristic';\nmsg.confidence = data.confidence || '—';\nmsg.context_label = data.context_label || '—';\nmsg.time = time;\n\nreturn [msg, msg, msg, msg];",
        "outputs": 4,
        "x": 370,
        "y": 440,
        "wires": [
            [
                "6ff66b30d8af4fb9"
            ],
            [
                "9e42022075a6c5a5"
            ],
            [
                "66a22080338cc35a"
            ],
            [
                "a3e9cb2dca52f031"
            ]
        ]
    },
    {
        "id": "6ff66b30d8af4fb9",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Karar",
        "func": "msg.payload = msg.time + '\\n' + msg.room + ' → ' + msg.device + ': ' + msg.command;\nreturn msg;",
        "outputs": 1,
        "x": 590,
        "y": 400,
        "wires": [
            [
                "cbc8c38571476af6"
            ]
        ]
    },
    {
        "id": "9e42022075a6c5a5",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Bağlam",
        "func": "msg.payload = msg.context_label + '\\nYöntem: ' + msg.method;\nreturn msg;",
        "outputs": 1,
        "x": 590,
        "y": 450,
        "wires": [
            [
                "95866571b31e4a9d"
            ]
        ]
    },
    {
        "id": "66a22080338cc35a",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Güven",
        "func": "msg.payload = msg.confidence;\nreturn msg;",
        "outputs": 1,
        "x": 590,
        "y": 500,
        "wires": [
            [
                "ebb653cc8a41aa8b"
            ]
        ]
    },
    {
        "id": "a3e9cb2dca52f031",
        "type": "function",
        "z": "44162578c2bd78b4",
        "name": "Gerekçe",
        "func": "msg.payload = msg.time + ' | ' + msg.reason;\nreturn msg;",
        "outputs": 1,
        "x": 590,
        "y": 550,
        "wires": [
