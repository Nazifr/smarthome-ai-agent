    {
        "id": "7ef3d89aa36cb7ba",
        "type": "mqtt in",
        "z": "44162578c2bd78b4",
        "name": "Sensör Verisi",
        "topic": "home/+/sensor/all",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt-broker-1",
        "inputs": 0,
        "x": 130,
        "y": 120,
