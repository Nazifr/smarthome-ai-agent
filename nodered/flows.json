    {
        "id": "0074574bfad9df1f",
        "type": "mqtt in",
        "z": "44162578c2bd78b4",
        "name": "Agent Komutları",
        "topic": "home/+/+/command",
        "qos": "0",
        "datatype": "json",
        "broker": "mqtt-broker-1",
        "inputs": 0,
        "x": 130,
        "y": 440,
        "wires": [
